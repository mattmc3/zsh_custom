#!/bin/zsh
#autoload
emulate -L zsh; setopt local_options extended_glob
(( $# >= 2 )) || return 1

local cmdname=$1; shift
local cachefile=${XDG_CACHE_HOME:-$HOME/.cache}/zsh/cached-eval/${cmdname}.zsh
local -a cached=($cachefile(Nmh-20))
if [[ ! -s $cachefile ]] || (( ! ${#cached} )); then
  mkdir -p ${cachefile:h}
  "$@" >| $cachefile
fi
source $cachefile
