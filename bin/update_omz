#!/bin/zsh

emulate -L zsh
setopt err_return no_unset pipe_fail

repo_root=${0:A:h:h}
target_plugins_dir="${repo_root}/plugins"
temp_dir="${repo_root}/.repos/ohmyzsh/ohmyzsh"
omz_repo_url="https://github.com/ohmyzsh/ohmyzsh.git"

# Add plugin names here as needed.
typeset -a omz_plugins
omz_plugins=(
  extract
)

if (( ! $+commands[rsync] )); then
  echo "This script requires rsync, but it was not found in PATH." >&2
  exit 1
fi

if [[ -d "${temp_dir}/.git" ]]; then
  git -C "$temp_dir" pull --ff-only
else
  git clone --depth=1 "$omz_repo_url" "$temp_dir"
fi

for plugin in $omz_plugins; do
  plugin_src="${temp_dir}/plugins/${plugin}"
  plugin_dst="${target_plugins_dir}/${plugin}"

  if [[ ! -d "$plugin_src" ]]; then
    echo "Plugin not found in oh-my-zsh repo: $plugin" >&2
    exit 1
  fi

  mkdir -p "$plugin_dst"
  rsync -a --delete "$plugin_src/" "$plugin_dst/"

  echo "Synced plugin: $plugin"
done
