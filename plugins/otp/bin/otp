#!/bin/sh

# otp - One-time passwords (multi-factor authentication from the command line)

die()  { warn "$@"; exit "${ERR:-1}"; }
say()  { printf '%s\n' "$@"; }
warn() { say "$@" >&2; }

OTP_HOME="${OTP_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/otp}"
[ -d "$OTP_HOME" ] || mkdir -p "$OTP_HOME"

usage() {
  say "usage: otp [-h|--help] [-l|--list] [-a|--add] [-r|--remove] [--rekey] [--list-pubkeys] <key>" \
      "  -h, --help          Show help" \
      "  -l, --list          List OTP keys" \
      "  -a, --add <key>     Add a new OTP key" \
      "  -r, --remove <key>  Remove an OTP key" \
      "      --rekey         Re-encrypt all OTP keys to current recipients" \
      "      --list-pubkeys  List GPG recipient pubkeys"
}

# Check dependencies
if ! command -v oathtool >/dev/null 2>&1; then
  die "otp: 'oathtool' not found. Install oathtool or oath-toolkit."
fi

if ! command -v gpg >/dev/null 2>&1; then
  die "otp: 'gpg' not found. Install, and create a key with 'gpg --gen-key'."
fi

# Collect GPG recipients from pubkeys/*.asc
RECIPIENTS=""
for pubkey in "$OTP_HOME"/pubkeys/*.asc; do
  [ -f "$pubkey" ] || continue
  keyid=$(gpg --show-keys --with-colons "$pubkey" 2>/dev/null | awk -F: '/^pub/ {print $5}')
  [ -n "$keyid" ] && RECIPIENTS="$RECIPIENTS --recipient $keyid"
done

# Parse options
flag_help=0
flag_list=0
flag_add=0
flag_remove=0
flag_rekey=0
flag_list_pubkeys=0
key=""

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)      flag_help=1 ;;
    -l|--list)      flag_list=1 ;;
    -a|--add)       flag_add=1 ;;
    -r|--remove)    flag_remove=1 ;;
    --rekey)        flag_rekey=1 ;;
    --list-pubkeys) flag_list_pubkeys=1 ;;
    *)              key="$1" ;;
  esac
  shift
done

if [ "$flag_help" -eq 1 ]; then
  usage
  exit 0
elif [ "$flag_list" -eq 1 ]; then
  for file in "$OTP_HOME"/*.otp.asc; do
    [ -f "$file" ] && basename "$file" .otp.asc
  done
  exit 0
elif [ "$flag_list_pubkeys" -eq 1 ]; then
  for pubkey in "$OTP_HOME"/pubkeys/*.asc; do
    [ -f "$pubkey" ] || continue
    say "$(basename "$pubkey"):"
    gpg --show-keys "$pubkey" 2>/dev/null | sed 's/^/  /'
  done
  exit 0
elif [ -z "$key" ]; then
  die "otp: Expecting <key> argument. Run 'otp -h' for usage."
elif [ "$flag_remove" -eq 1 ]; then
  if [ -z "$key" ]; then
    die "otp: Please specify a key to remove."
  fi
  if [ -f "$OTP_HOME/$key.otp.asc" ]; then
    rm -f "$OTP_HOME/$key.otp.asc"
    say "otp: Removed key '$key'."
    exit 0
  else
    die "otp: Key '$key' not found."
  fi
elif [ "$flag_add" -eq 1 ]; then
  say "The 'otp' utility uses gpg to encrypt your OTP key."
  printf "Enter the OTP secret for '%s': " "$key"
  stty -echo
  read -r otp_secret
  stty echo
  say
  rm -f -- "${OTP_HOME:?}/$key.otp.asc"
  # shellcheck disable=SC2086
  say "$otp_secret" | gpg $RECIPIENTS --armor --encrypt --output "$OTP_HOME/$key.otp.asc"
  exit 0
elif [ "$flag_rekey" -eq 1 ]; then
  for file in "$OTP_HOME"/*.otp.asc; do
    [ -f "$file" ] || continue
    totpkey=$(gpg --quiet --decrypt "$file" 2>/dev/null)
    if [ -z "$totpkey" ]; then
      die "otp: failed to decrypt $file"
    fi
    # shellcheck disable=SC2086
    if say "$totpkey" | gpg $RECIPIENTS --armor --encrypt --output "$file.new"; then
      mv -f "$file.new" "$file"
    else
      rm -f "$file.new"
      die "otp: failed to rekey $file"
    fi
  done
  exit 0
elif [ ! -f "$OTP_HOME/$key.otp.asc" ]; then
  die "otp: missing key '$key'. Run 'otp --add <key>' to add a new one-time password."
else
  totpkey=$(gpg --quiet --decrypt "$OTP_HOME/$key.otp.asc" 2>/dev/null)
  if [ -z "$totpkey" ]; then
    die "No OTP value or failed to decrypt key: $key"
  fi
  if command -v pbcopy >/dev/null 2>&1; then
    oathtool --totp --b "$totpkey" | tee /dev/stderr | pbcopy
  else
    oathtool --totp --b "$totpkey"
  fi
fi
