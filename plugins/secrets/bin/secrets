#!/bin/sh

# secrets - gpg-encrypted secrets with git-safe storage
#
# Plaintext working files live at natural paths under the base dir in any
# structure. Encrypted shadows mirror that structure under .secrets/store/,
# and recipient pubkeys live in .secrets/keys/. Only .secrets/ belongs in
# source control.

die()  { warn "$@"; exit "${ERR:-1}"; }
say()  { printf '%s\n' "$@"; }
warn() { say "$@" >&2; }

SECRETS_HOME="${SECRETS_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/secrets}"
umask 077

usage() {
  say "usage: secrets [-C <dir>] <command>" \
      "  init <gpg-key>...   Create a secrets dir encrypting to the given key(s)" \
      "  home                Print the secrets directory path" \
      "  keys                List recipient keys" \
      "  keys add <key>...   Add recipient key(s) from your gpg keyring" \
      "  keys remove <key>   Remove a recipient key (at least one must remain)" \
      "  status              Show what is out of sync" \
      "  encrypt [path...]   Encrypt files into .secrets/store/ shadows" \
      "  decrypt [--force] [path...]" \
      "                      Restore plaintext files from shadows" \
      "  rm <path>...        Remove a secret (plaintext and shadow)" \
      "  prune [--force]     Remove shadows whose plaintext is gone (dry run by default)" \
      "  help                Show help" \
      "" \
      "  -C <dir>            Operate on <dir> instead of \$SECRETS_HOME" \
      "      --force         decrypt: overwrite plaintexts that differ from their shadow" \
      "" \
      "Adding or removing keys automatically re-encrypts all shadows."
}

command -v gpg >/dev/null 2>&1 || die "secrets: 'gpg' not found."

check_home() {
  if [ ! -d "$SECRETS_HOME/.secrets" ]; then
    die "secrets: $SECRETS_HOME is not a secrets dir. Run 'secrets init <gpg-key>' first."
  fi
}

# Record the encryption subkey ids from .secrets/keys/*.asc so encrypt can
# tell when a shadow's recipients are stale. Encryption itself reads the
# pubkey files directly (--recipient-file), no keyring import needed.
collect_recipients() {
  subkeys=""
  for pubkey in "$KEYS_DIR"/*.asc; do
    [ -f "$pubkey" ] || continue
    subkey=$(gpg --show-keys --with-colons "$pubkey" 2>/dev/null |
      awk -F: '$1 == "sub" && $12 ~ /e/ {k = $5} END {if (k) print k}')
    [ -n "$subkey" ] && subkeys="$subkeys$subkey
"
  done
  if [ -z "$subkeys" ]; then
    die "secrets: no recipient keys found in $KEYS_DIR." \
        "Add one with 'secrets keys add <gpg-key>'."
  fi
  EXPECTED_KEYIDS=$(printf '%s' "$subkeys" | sort)
}

shadow_keyids() {
  gpg --list-only -v --decrypt -- "$1" 2>&1 |
    awk '/public key is/ {print $NF}' | sort
}

# A shadow is current when its recipients match .secrets/keys/ and it
# decrypts to the same content as the plaintext
shadow_current() {
  [ "$(shadow_keyids "$1")" = "$EXPECTED_KEYIDS" ] || return 1
  gpg --quiet --yes --decrypt --output "$tmpfile" -- "$1" 2>/dev/null || return 1
  cmp -s -- "$tmpfile" "$2"
}

# Plaintext candidates: skip hidden dirs (.secrets, .git), encrypted files,
# and repo machinery. Hidden files like .envrc are secrets too.
find_plaintext() {
  # -H: follow $SECRETS_HOME itself if it is a symlink
  find -H "$SECRETS_HOME" \
    \( -type d -name '.*' ! -path "$SECRETS_HOME" -prune \) -o \
    \( -type f ! -name '*.asc' ! -name 'README.md' \
       ! -name '.gitignore' ! -name '.gitkeep' ! -name '.secretsignore' -print \)
}

# Match relpath against .secretsignore globs (against full relative path
# and basename). No negation or gitignore extras; just shell globs.
ignored() {
  [ -f "$SECRETS_HOME/.secretsignore" ] || return 1
  while IFS= read -r pat; do
    case "$pat" in ''|'#'*) continue ;; esac
    # shellcheck disable=SC2254
    case "$1" in $pat) return 0 ;; esac
    # shellcheck disable=SC2254
    case "${1##*/}" in $pat) return 0 ;; esac
  done < "$SECRETS_HOME/.secretsignore"
  return 1
}

find_shadows() {
  [ -d "$STORE_DIR" ] || return 0
  find -H "$STORE_DIR" -name '*.asc' -type f
}

shadow_for() {
  say "$STORE_DIR/${1#"$SECRETS_HOME"/}.asc"
}

plain_for() {
  rel="${1#"$STORE_DIR"/}"
  say "$SECRETS_HOME/${rel%.asc}"
}

relpath() {
  say "${1#"$SECRETS_HOME"/}"
}

# Encrypt src to shadow via a temp file so failures never clobber it.
# Recipients come straight from the pubkey files.
encrypt_to() {
  ec_src="$1"
  ec_dst="$2"
  set -- --armor --encrypt --yes --output "$ec_dst.new"
  for pubkey in "$KEYS_DIR"/*.asc; do
    [ -f "$pubkey" ] || continue
    set -- "$@" --recipient-file "$pubkey"
  done
  if gpg "$@" -- "$ec_src" 2>/dev/null; then
    mv -f "$ec_dst.new" "$ec_dst"
  else
    rm -f "$ec_dst.new"
    return 1
  fi
}

encrypt_one() {
  out=$(shadow_for "$1")
  if [ -f "$out" ] && shadow_current "$out" "$1"; then
    return 0
  fi
  mkdir -p "$(dirname "$out")"
  if encrypt_to "$1" "$out"; then
    say "encrypted: $(relpath "$1")"
  else
    die "secrets: failed to encrypt $(relpath "$1")"
  fi
}

# Re-encrypt shadows whose plaintext is present and stale
do_encrypt() {
  find_plaintext | while read -r file; do
    ignored "$(relpath "$file")" && continue
    encrypt_one "$file"
  done || die "secrets: encrypt failed."
}

# Targeted encrypt; explicit paths bypass .secretsignore
cmd_encrypt_paths() {
  collect_recipients
  tmpfile=$(mktemp) || die "secrets: could not create temp file."
  trap 'rm -f "$tmpfile"' EXIT INT TERM
  for arg in "$@"; do
    file="$SECRETS_HOME/${arg#"$SECRETS_HOME"/}"
    [ -f "$file" ] || die "secrets: no file '$(relpath "$file")'."
    unsafe_plain "$(relpath "$file")" && die "secrets: refusing to encrypt repo machinery: $(relpath "$file")"
    encrypt_one "$file"
  done
}

# Re-encrypt shadows with stale recipients from the shadow itself. Covers
# shadows whose plaintext is not present; needs a secret key that can
# decrypt them.
do_rekey() {
  find_shadows | while read -r shadow; do
    [ "$(shadow_keyids "$shadow")" = "$EXPECTED_KEYIDS" ] && continue
    if ! gpg --quiet --yes --decrypt --output "$tmpfile" -- "$shadow" 2>/dev/null; then
      die "secrets: cannot rekey $(relpath "$(plain_for "$shadow")"):" \
          "no plaintext and no secret key able to decrypt it."
    fi
    if encrypt_to "$tmpfile" "$shadow"; then
      say "rekeyed: $(relpath "$(plain_for "$shadow")")"
    else
      die "secrets: failed to rekey $(relpath "$(plain_for "$shadow")")"
    fi
  done || die "secrets: rekey failed."
}

reencrypt_all() {
  collect_recipients
  tmpfile=$(mktemp) || die "secrets: could not create temp file."
  trap 'rm -f "$tmpfile"' EXIT INT TERM
  do_encrypt
  do_rekey
}

# Report files out of sync between plaintexts and shadows. In-sync files
# print nothing, like git status.
cmd_status() {
  collect_recipients
  tmpfile=$(mktemp) || die "secrets: could not create temp file."
  trap 'rm -f "$tmpfile"' EXIT INT TERM
  found=$( (
    find_plaintext | while read -r file; do
      ignored "$(relpath "$file")" && continue
      shadow=$(shadow_for "$file")
      if [ ! -f "$shadow" ]; then
        say "unencrypted:   $(relpath "$file")"
      elif ! gpg --quiet --yes --decrypt --output "$tmpfile" -- "$shadow" 2>/dev/null; then
        say "undecryptable: $(relpath "$file")"
      elif ! cmp -s -- "$tmpfile" "$file"; then
        say "modified:      $(relpath "$file")"
      elif [ "$(shadow_keyids "$shadow")" != "$EXPECTED_KEYIDS" ]; then
        say "stale keys:    $(relpath "$file")"
      fi
    done
    find_shadows | while read -r shadow; do
      plain=$(plain_for "$shadow")
      [ -f "$plain" ] || say "not decrypted: $(relpath "$plain")"
    done
  ) )
  if [ -n "$found" ]; then
    say "$found"
    say "" "'secrets encrypt' fixes unencrypted, modified, and stale keys;" \
        "'secrets decrypt' restores not decrypted files."
  else
    say "secrets: everything in sync."
  fi
}

# Restoring repo machinery or writing inside hidden dirs is never
# legitimate (encrypt refuses those paths), only an attack via a crafted
# shadow in the store. Final path component may be hidden (eg: .envrc).
unsafe_plain() {
  up_dir=${1%/*}
  if [ "$up_dir" != "$1" ]; then
    case "/$up_dir/" in */.*) return 0 ;; esac
  fi
  case "${1##*/}" in
    .gitignore|.secretsignore|.gitkeep|README.md) return 0 ;;
  esac
  return 1
}

decrypt_one() {
  plain=$(plain_for "$1")
  if unsafe_plain "$(relpath "$plain")"; then
    warn "secrets: refusing to restore suspicious shadow: $(relpath "$1")"
    return 0
  fi
  if ! gpg --quiet --yes --decrypt --output "$tmpfile" -- "$1" 2>/dev/null; then
    die "secrets: failed to decrypt $(relpath "$1")"
  fi
  if [ -f "$plain" ]; then
    cmp -s -- "$tmpfile" "$plain" && return 0
    if [ "$flag_force" -eq 0 ]; then
      warn "secrets: $(relpath "$plain") differs from its shadow;" \
           "  'secrets encrypt' keeps your local changes, 'secrets decrypt --force' discards them."
      return 0
    fi
  fi
  mkdir -p "$(dirname "$plain")"
  cp -f -- "$tmpfile" "$plain" || die "secrets: failed to write $(relpath "$plain")"
  chmod 600 "$plain"
  say "decrypted: $(relpath "$plain")"
}

cmd_decrypt() {
  tmpfile=$(mktemp) || die "secrets: could not create temp file."
  trap 'rm -f "$tmpfile"' EXIT INT TERM
  if [ $# -gt 0 ]; then
    for arg in "$@"; do
      rel="${arg#"$SECRETS_HOME"/}"
      shadow="$STORE_DIR/$rel.asc"
      [ -f "$shadow" ] || die "secrets: no shadow for '$rel'."
      decrypt_one "$shadow"
    done
  else
    find_shadows | while read -r shadow; do
      decrypt_one "$shadow"
    done || die "secrets: decrypt failed."
  fi
}

cmd_rm() {
  [ $# -gt 0 ] || die "secrets: usage: secrets rm <path>..."
  for arg in "$@"; do
    rel="${arg#"$SECRETS_HOME"/}"
    plain="$SECRETS_HOME/$rel"
    shadow="$STORE_DIR/$rel.asc"
    if [ ! -f "$plain" ] && [ ! -f "$shadow" ]; then
      die "secrets: no secret '$rel'."
    fi
    rm -f -- "$plain" "$shadow"
    rmdir -p -- "$(dirname "$shadow")" 2>/dev/null
    say "removed: $rel"
  done
}

# Orphaned shadows (no plaintext). Dry run by default; --force deletes.
cmd_prune() {
  if [ "$flag_force" -eq 1 ]; then
    find_shadows | while read -r shadow; do
      plain=$(plain_for "$shadow")
      [ -f "$plain" ] && continue
      rm -f -- "$shadow"
      rmdir -p -- "$(dirname "$shadow")" 2>/dev/null
      say "pruned: $(relpath "$plain")"
    done
  else
    orphans=$(find_shadows | while read -r shadow; do
      plain=$(plain_for "$shadow")
      [ -f "$plain" ] || say "  $(relpath "$plain")"
    done)
    if [ -n "$orphans" ]; then
      say "secrets: shadows with no plaintext:" "$orphans" \
          "Run 'secrets decrypt' to restore them, or 'secrets prune --force' to delete them."
    else
      say "secrets: nothing to prune."
    fi
  fi
}

keys_list() {
  for pubkey in "$KEYS_DIR"/*.asc; do
    [ -f "$pubkey" ] || continue
    say "$(basename "$pubkey"):"
    gpg --show-keys "$pubkey" 2>/dev/null | sed 's/^/  /'
  done
}

keys_add() {
  [ $# -gt 0 ] || die "secrets: 'keys add' requires at least one gpg key id."
  mkdir -p "$KEYS_DIR"
  for arg in "$@"; do
    keyinfo=$(gpg --list-keys --with-colons -- "$arg" 2>/dev/null)
    fpr=$(say "$keyinfo" | awk -F: '/^fpr/ {print $10; exit}')
    [ -n "$fpr" ] || die "secrets: gpg key '$arg' not found in keyring."
    email=$(say "$keyinfo" |
      awk -F: '/^uid/ {print $10; exit}' | sed -n 's/.*<\(.*\)>.*/\1/p')
    keyid=$(say "$fpr" | awk '{print substr($0, length($0) - 15)}')
    fname="$keyid.asc"
    [ -n "$email" ] && fname="$keyid-$(say "$email" | sed 's/@/-at-/; s/\./-dot-/g').asc"
    gpg --armor --export -- "$fpr" > "$KEYS_DIR/$fname" || die "secrets: failed to export '$arg'."
    say "added key: $fname"
  done
}

keys_remove() {
  [ $# -eq 1 ] || die "secrets: usage: secrets keys remove <gpg-key>"
  needle=$(say "$1" | tr '[:lower:]' '[:upper:]')
  match=""
  nkeys=0
  for pubkey in "$KEYS_DIR"/*.asc; do
    [ -f "$pubkey" ] || continue
    nkeys=$((nkeys + 1))
    fpr=$(gpg --show-keys --with-colons "$pubkey" 2>/dev/null | awk -F: '/^fpr/ {print $10; exit}')
    hay=$(say "$(basename "$pubkey")|$fpr" | tr '[:lower:]' '[:upper:]')
    case "$hay" in
      *"$needle"*)
        [ -n "$match" ] && die "secrets: '$1' matches more than one key."
        match="$pubkey"
        ;;
    esac
  done
  [ -n "$match" ] || die "secrets: no recipient key matching '$1'."
  if [ "$nkeys" -le 1 ]; then
    die "secrets: cannot remove the last recipient key."
  fi
  rm -f "$match"
  say "removed key: $(basename "$match")"
}

cmd_keys() {
  sub="$1"
  [ $# -gt 0 ] && shift
  case "$sub" in
    ""|list) keys_list ;;
    add)     keys_add "$@"; reencrypt_all ;;
    remove|rm) keys_remove "$@"; reencrypt_all ;;
    *) die "secrets: unknown command 'keys $sub'. Run 'secrets help' for usage." ;;
  esac
}

cmd_init() {
  if [ $# -eq 0 ] && ! ls "$KEYS_DIR"/*.asc >/dev/null 2>&1; then
    die "secrets: init requires at least one gpg key id to encrypt to." \
        "usage: secrets init <gpg-key>..."
  fi
  mkdir -p "$KEYS_DIR" "$STORE_DIR"
  if [ ! -f "$SECRETS_HOME/.gitignore" ]; then
    cat > "$SECRETS_HOME/.gitignore" <<'EOF'
# Plaintext secrets never belong in git; only encrypted .secrets/ does
/*
!/.secrets
!/.gitignore
!/.secretsignore
!/README.md
EOF
    say "secrets: created $SECRETS_HOME/.gitignore"
  fi
  if [ ! -f "$SECRETS_HOME/.secretsignore" ]; then
    cat > "$SECRETS_HOME/.secretsignore" <<'EOF'
# Files that should never be encrypted. Shell globs: a bare name matches
# at any depth, a pattern with / is anchored to this dir.
.DS_Store
EOF
    say "secrets: created $SECRETS_HOME/.secretsignore"
  fi
  [ $# -gt 0 ] && keys_add "$@"
  say "secrets: put files anywhere under $SECRETS_HOME and run 'secrets encrypt'."
}

# Parse options
cmd=""
flag_force=0
while [ $# -gt 0 ]; do
  case "$1" in
    -C)
      [ -n "$2" ] || die "secrets: -C requires a directory."
      SECRETS_HOME="$2"
      shift
      ;;
    -f|--force) flag_force=1 ;;
    -h|--help) cmd="help" ;;
    -*) die "secrets: unknown option '$1'. Run 'secrets help' for usage." ;;
    *) cmd="$1"; shift; break ;;
  esac
  shift
done

KEYS_DIR="$SECRETS_HOME/.secrets/keys"
STORE_DIR="$SECRETS_HOME/.secrets/store"

case "$cmd" in
  init)    cmd_init "$@" ;;
  home)    say "$SECRETS_HOME" ;;
  keys)    check_home; cmd_keys "$@" ;;
  status)  check_home; cmd_status ;;
  encrypt)
    check_home
    if [ $# -gt 0 ]; then
      cmd_encrypt_paths "$@"
    else
      reencrypt_all
    fi
    ;;
  decrypt)
    check_home
    n=$#
    while [ "$n" -gt 0 ]; do
      arg="$1"
      shift
      n=$((n - 1))
      case "$arg" in
        -f|--force) flag_force=1 ;;
        *) set -- "$@" "$arg" ;;
      esac
    done
    cmd_decrypt "$@"
    ;;
  rm)
    check_home
    cmd_rm "$@"
    ;;
  prune)
    check_home
    for arg in "$@"; do
      case "$arg" in
        -f|--force) flag_force=1 ;;
        *) die "secrets: unexpected argument '$arg'." ;;
      esac
    done
    cmd_prune
    ;;
  ""|help) usage ;;
  *) die "secrets: unknown command '$cmd'. Run 'secrets help' for usage." ;;
esac
